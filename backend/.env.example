PORT=8000
HOST=0.0.0.0
ENVIRONMENT=development
DATABASE_URL=sqlite:///./maali_mentor.db

# ── Gemini AI (required for tutor, embeddings, and STT) ──────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-actual-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-3.1-flash-lite

# ── Speech (optional – ElevenLabs for premium TTS) ───────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Mock flags ────────────────────────────────────────────────────────────
# Set to true ONLY for offline development without an API key.
# Production deployments must set both to false.
USE_MOCK_SPEECH=false
USE_MOCK_LLM=false

# ── CORS (comma-separated allowed frontend origins) ──────────────────────
ALLOWED_ORIGINS=http://localhost:3000
